# ──────────────────────────────────────────────────────────────
# CES ERP frontend — mühit konfiqurasiyası ŞABLONU
# Bu faylı `.env` adı ilə kopyalayın və öz mühitinizə uyğun doldurun:
#   cp .env.example .env
# `.env` faylı git-ə commit olunmur.
# ──────────────────────────────────────────────────────────────

# Vite dev server-in /api sorğularını ötürdüyü backend ünvanı (YALNIZ `npm run dev`)
VITE_API_TARGET=http://localhost:8083

# Frontend-in API əsas yolu. Default relativ `/api` (prod-da nginx proxy edir).
VITE_API_BASE_URL=/api

# Dev server portu
VITE_PORT=3000
